# ============================================================
# Cérebro Python — variáveis de ambiente (exemplo)
# Copia para .env e preenche com valores reais (NUNCA commitar .env)
# ============================================================

# --- API ---
API_HOST=0.0.0.0
API_PORT=8001
LOG_LEVEL=INFO

# --- LLMs ---
OPENAI_API_KEY=sk-...
BOT_ROUTER_MODEL=gpt-4o-mini
BOT_TRIAGE_MODEL=gpt-4.1-mini
BOT_SPECIALIST_MODEL=gpt-4.1-mini
BOT_SCHEDULING_MODEL=gpt-4.1-mini
BOT_INTENT_MODEL=gpt-4o-mini

# --- Supabase / Postgres ---
# Usar SEMPRE o Connection Pooler (porta 6543, modo transaction) — não o direct connect (5432)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Embeddings (RAG) ---
HF_API_TOKEN=hf_...
HF_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Comportamento ---
BOT_SETTLE_MS=4000
BOT_LOCK_TTL=30
